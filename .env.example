# ==============================================================================
# Domain-Independent RAG with Citation Verifiability - Environment Settings
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Configuration
# ------------------------------------------------------------------------------

# Supported: ollama | groq
LLM_PROVIDER=groq

# Groq API Key (Replace with your actual API key)
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Recommended Groq Model
LLM_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------------------------
# Ollama Configuration (Ignored when using Groq)
# ------------------------------------------------------------------------------

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# ------------------------------------------------------------------------------
# Embedding & Reranker Models
# ------------------------------------------------------------------------------

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# ------------------------------------------------------------------------------
# Security Configuration
# ------------------------------------------------------------------------------

ALLOWED_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE=20971520

# ------------------------------------------------------------------------------
# Storage Configuration
# ------------------------------------------------------------------------------

DATA_DIR=./data
CHROMA_DB_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads
SQLITE_DB_PATH=./data/rag_system.db
HF_HOME=./data/hf_cache

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------

LOG_LEVEL=INFO